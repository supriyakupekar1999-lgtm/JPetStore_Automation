pipeline {
    agent any

    tools {
        jdk 'JDK17'
        maven 'maven-3.9.16'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/supriyakupekar1999-lgtm/JPetStore_Automation.git'
            }
        }

        stage('Build & Test') {
            steps {
                bat 'java -version'
                bat 'mvn clean test'
            }
        }
    }

    post {
        always {
            junit 'target/surefire-reports/*.xml'
        }
    }
}
